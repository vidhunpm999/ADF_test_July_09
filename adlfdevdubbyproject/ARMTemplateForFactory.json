						],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@activity('Lookup_adls').output.value",
								"type": "Expression"
							},
							"condition": {
								"value": "@or(equals(item().SIC_code, '1110'), equals(item().SIC_code, '1120'))",
								"type": "Expression"
							}
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
